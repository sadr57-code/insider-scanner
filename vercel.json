{
  "version": 2,
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/insiders.js": {
      "maxDuration": 30
    },
    "api/users.js": {
      "maxDuration": 10
    },
    "api/debug.js": {
      "maxDuration": 15
    },
    "api/congress.js": {
      "maxDuration": 60
    }
  }
}
