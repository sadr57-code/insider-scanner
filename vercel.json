{
  "version": 2,
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/congress-fetch", "schedule": "0 9 * * 1-5" }
  ],
  "functions": {
    "api/insiders.js":         { "maxDuration": 30 },
    "api/users.js":            { "maxDuration": 10 },
    "api/debug.js":            { "maxDuration": 15 },
    "api/congress.js":         { "maxDuration": 10 },
    "api/congress-fetch.js":   { "maxDuration": 10 },
    "api/congress-webhook.js": { "maxDuration": 10 }
  }
}